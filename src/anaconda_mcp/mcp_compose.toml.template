# MCP Compose Configuration Template
#
# ✅ This is the PRIMARY configuration file
# ✅ Edit this file to customize your configuration
# ✅ Use {{PYTHON_EXECUTABLE}} for dynamic Python path injection
#
# The {{PYTHON_EXECUTABLE}} placeholder will be replaced at runtime with:
# 1. ANACONDA_MCP_PYTHON_EXECUTABLE environment variable (if set), or
# 2. sys.executable (the Python interpreter running anaconda-mcp)
#
# The {{ANACONDA_DOMAIN}} placeholder will be replaced at runtime with:
# 1. ANACONDA_MCP_ANACONDA_DOMAIN environment variable (if set), or
# 2. Domain derived from ANACONDA_MCP_ENVIRONMENT (staging → stage.anaconda.com), or
# 3. "anaconda.com" (default)
#
# This file demonstrates all available configuration options

# ============================================================================
# Composer Settings
# ============================================================================
[composer]
name = "anaconda-mcp"
prune_downstreams_on_start = true
conflict_resolution = "prefix"  # prefix, suffix, ignore, error, override, custom
log_level = "INFO"
port = 2391

# ============================================================================
# Transport Configuration
# ============================================================================
[transport]
stdio_enabled = true
streamable_http_enabled = false
sse_enabled = false

# ============================================================================
# Authentication Configuration (Optional)
# ============================================================================
[authentication]
enabled = false
providers = ["anaconda"]
default_provider = "anaconda"

[authentication.anaconda]
domain = "anaconda.com"

# ============================================================================
# Embedded MCP Servers
# ============================================================================

# ============================================================================
# Proxied Streamable HTTP MCP Servers
# ============================================================================
[[servers.proxied.streamable-http]]
name = "conda"
url = "http://localhost:4041/mcp"
timeout = 30
keep_alive = true
reconnect_on_failure = true
max_reconnect_attempts = 10
health_check_enabled = false
mode = "proxy"
auto_start = true
command = ["{{PYTHON_EXECUTABLE}}", "-m", "environments_mcp_server", "start", "--transport", "streamable-http", "--port", "4041"]
startup_delay = 3

[[servers.proxied.streamable-http]]
name = "search"
url = "https://{{ANACONDA_DOMAIN}}/api/search/mcp"
auth_token = "{{ANACONDA_TOKEN}}"
auth_type = "bearer"
timeout = 30
keep_alive = true
reconnect_on_failure = true
max_reconnect_attempts = 10
health_check_enabled = false
mode = "proxy"

# ============================================================================
# Tool Manager Configuration
# ============================================================================
[tool_manager]
conflict_resolution = "prefix"

[tool_manager.custom_template]
template = "{tool_name}"


[tool_manager.versioning]
enabled = false
allow_multiple_versions = false
version_suffix_format = "_v{version}"

# ============================================================================
# REST API Configuration
# ============================================================================
[api]
enabled = true
path_prefix = "/api/v1"
host = "0.0.0.0"
port = 8888
cors_enabled = true
cors_origins = ["http://localhost:3000"]
cors_methods = ["GET", "POST", "PUT", "DELETE"]
docs_enabled = true
docs_path = "/docs"
openapi_path = "/openapi.json"
